{
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "output_dir": "artifacts/models/full_data_c11_stage_phenology_light_epoch112",
  "seed": 42,
  "batch_size": 256,
  "epochs": 112,
  "learning_rate": 0.0003,
  "weight_decay": 0.03,
  "num_workers": 4,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 1,
  "clip_grad_norm": 1.0,
  "scheduler": "cosine",
  "warmup_epochs": 5,
  "stage_loss_weight": 0.6,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.0,
  "include_valid_mask_as_channels": true,
  "min_lr": 0.000001,
  "use_aux_features": true,
  "aux_feature_set": "phenology_light",
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "cnn_embedding_dim": 256,
    "transformer_dim": 256,
    "transformer_layers": 4,
    "attention_heads": 8,
    "dropout": 0.18,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_query_doy": true,
    "use_time_doy": true,
    "aux_hidden_dim": 64,
    "aux_target": "stage_only"
  },
  "selection_rule": "Full-data C11 uses all labeled samples for 112 fixed epochs, matching the best tie-breaker epoch from C11 validation where val_competition_score was 1.0 and val_loss was lowest."
}
