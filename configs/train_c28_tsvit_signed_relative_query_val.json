{
  "model_type": "query_tsvit",
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "split_csv": "artifacts/splits/train_val_split.csv",
  "output_dir": "artifacts/models/c28_tsvit_signed_relative_query_val",
  "seed": 42,
  "batch_size": 96,
  "epochs": 220,
  "learning_rate": 0.0003,
  "weight_decay": 0.03,
  "num_workers": 4,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 2,
  "clip_grad_norm": 1.0,
  "scheduler": "cosine",
  "warmup_epochs": 8,
  "early_stopping_patience": 35,
  "save_best_only": true,
  "stage_loss_weight": 0.6,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.0,
  "stage_sequence_loss_weight": 0.05,
  "stage_max_forward_step": 1.5,
  "stage_postprocess": "transition_viterbi",
  "include_valid_mask_as_channels": true,
  "random_time_shift_days": 45,
  "query_doy_dropout_prob": 0.35,
  "time_doy_dropout_prob": 0.15,
  "min_lr": 0.0,
  "checkpoint_metric": "val_competition_score",
  "tie_breaker_metric": "val_loss",
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "token_patch_size": 3,
    "transformer_dim": 320,
    "temporal_layers": 6,
    "spatial_layers": 6,
    "attention_heads": 8,
    "mlp_ratio": 4.0,
    "dropout": 0.15,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_query_doy": true,
    "use_time_doy": true,
    "time_encoding_type": "fourier",
    "query_encoding_type": "fourier",
    "time_encoding_harmonics": 8,
    "use_relative_query_bias": true
  },
  "selection_rule": "C28 TSViT-style heavy model: factorized temporal-then-spatial transformer with signed relative query-time encoding, task-specific temporal pooling, class-token spatial decoding, and mild date robustness augmentation."
}
