{
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "output_dir": "artifacts/models/full_data_c19_strong_date_shift_dropout_epoch58",
  "seed": 42,
  "batch_size": 256,
  "epochs": 58,
  "learning_rate": 0.0004,
  "weight_decay": 0.03,
  "num_workers": 6,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 2,
  "clip_grad_norm": 1.0,
  "scheduler": "cosine",
  "warmup_epochs": 5,
  "stage_loss_weight": 0.6,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.0,
  "include_valid_mask_as_channels": true,
  "min_lr": 0.0,
  "use_aux_features": false,
  "random_time_shift_days": 60,
  "query_doy_dropout_prob": 0.55,
  "time_doy_dropout_prob": 0.20,
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "cnn_embedding_dim": 256,
    "transformer_dim": 256,
    "transformer_layers": 4,
    "attention_heads": 8,
    "dropout": 0.18,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_query_doy": true,
    "use_time_doy": true
  },
  "selection_rule": "Full-data C19 uses all labeled samples for 58 fixed epochs, matching the planned C19 validation run where val_competition_score reached 1.0 at epoch 58 under strong date-shift and DOY-dropout regularization."
}
