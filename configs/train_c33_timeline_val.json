{
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "split_csv": "artifacts/splits/train_val_split.csv",
  "output_dir": "artifacts/models/c33_timeline_val",
  "seed": 42,
  "model_type": "season_timeline_transformer",
  "batch_size": 512,
  "epochs": 120,
  "learning_rate": 0.0003,
  "weight_decay": 0.03,
  "num_workers": 8,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 1,
  "persistent_workers": true,
  "prefetch_factor": 4,
  "clip_grad_norm": 1.0,
  "scheduler": "cosine",
  "warmup_epochs": 5,
  "early_stopping_patience": 24,
  "save_best_only": true,
  "crop_loss_weight": 0.2,
  "stage_loss_weight": 1.0,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.0,
  "stage_label_smoothing": 0.02,
  "include_valid_mask_as_channels": true,
  "min_lr": 0.0,
  "checkpoint_metric": "val_rice_stage_macro_f1",
  "tie_breaker_metric": "val_loss",
  "use_aux_features": false,
  "use_relative_doy": false,
  "stage_ordinal_loss_weight": 0.05,
  "stage_postprocess": "none",
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "cnn_embedding_dim": 256,
    "transformer_dim": 256,
    "transformer_layers": 4,
    "attention_heads": 8,
    "dropout": 0.18,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_time_doy": true,
    "time_encoding_type": "fourier",
    "time_encoding_harmonics": 6,
    "timeline_hidden_dim": 128,
    "stage_temperature_days": 12.0,
    "max_first_boundary_offset_days": 120.0,
    "min_transition_span_days": 45.0,
    "max_transition_span_days": 210.0,
    "min_transition_gap_days": 7.0
  },
  "selection_rule": "C33 timeline model: infer an ordered rice phenology timeline from imagery alone, then convert query_doy into a stage only at the final lookup. This removes query-date conditioning from the stage representation itself."
}
