{
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "split_csv": "artifacts/splits/train_val_split.csv",
  "output_dir": "artifacts/models/c30_c03_stage_robust_val",
  "seed": 42,
  "batch_size": 256,
  "epochs": 140,
  "learning_rate": 0.00035,
  "weight_decay": 0.03,
  "num_workers": 6,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 2,
  "clip_grad_norm": 1.0,
  "scheduler": "cosine",
  "warmup_epochs": 5,
  "early_stopping_patience": 24,
  "save_best_only": true,
  "stage_loss_weight": 0.8,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.0,
  "stage_label_smoothing": 0.03,
  "include_valid_mask_as_channels": true,
  "min_lr": 0.0,
  "checkpoint_metric": "val_loss",
  "tie_breaker_metric": "val_joint_accuracy_consistent",
  "use_aux_features": true,
  "aux_feature_set": "phenology_light",
  "use_relative_doy": true,
  "random_time_shift_days": 21,
  "query_doy_dropout_prob": 0.12,
  "time_doy_dropout_prob": 0.05,
  "stage_ordinal_loss_weight": 0.10,
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "cnn_embedding_dim": 256,
    "transformer_dim": 256,
    "transformer_layers": 4,
    "attention_heads": 8,
    "dropout": 0.18,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_query_doy": true,
    "use_time_doy": true,
    "time_encoding_type": "fourier",
    "query_encoding_type": "fourier",
    "time_encoding_harmonics": 6,
    "aux_hidden_dim": 64,
    "aux_target": "stage_only",
    "use_cross_series_query": true
  },
  "selection_rule": "C30 hidden-oriented rice-stage robustness. Start from the C03 family, encode query date relative to the observed series, use Fourier seasonal encoding, route phenology-light aux features only to the stage head, add mild relative-date corruption, and regularize stage targets with a small ordinal penalty plus stage-only label smoothing."
}
