{
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "split_csv": "artifacts/splits/train_val_split.csv",
  "output_dir": "artifacts/models/modeldev_c05_phenology_aux_features",
  "seed": 42,
  "batch_size": 128,
  "epochs": 90,
  "learning_rate": 0.00025,
  "weight_decay": 0.03,
  "num_workers": 4,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 1,
  "clip_grad_norm": 1.0,
  "scheduler": "cosine",
  "warmup_epochs": 5,
  "early_stopping_patience": 12,
  "save_best_only": true,
  "stage_loss_weight": 0.6,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.0,
  "include_valid_mask_as_channels": true,
  "checkpoint_metric": "val_competition_score",
  "tie_breaker_metric": "val_loss",
  "min_lr": 0.000001,
  "use_aux_features": true,
  "aux_feature_set": "phenology",
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "cnn_embedding_dim": 256,
    "transformer_dim": 256,
    "transformer_layers": 4,
    "attention_heads": 8,
    "dropout": 0.18,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_query_doy": true,
    "use_time_doy": true,
    "aux_hidden_dim": 128
  },
  "training_note": "C05: C04-style auxiliary branch using summary features plus phenology-relative query/curve features computed from the existing NPZ at dataset load time."
}
