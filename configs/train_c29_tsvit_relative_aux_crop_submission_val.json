{
  "model_type": "query_tsvit",
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "split_csv": "artifacts/splits/train_val_split.csv",
  "output_dir": "artifacts/models/c29_tsvit_relative_aux_crop_submission_val",
  "seed": 42,
  "batch_size": 224,
  "epochs": 140,
  "learning_rate": 0.00018,
  "weight_decay": 0.02,
  "num_workers": 8,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 1,
  "clip_grad_norm": 0.8,
  "scheduler": "cosine",
  "warmup_epochs": 10,
  "early_stopping_patience": 16,
  "save_best_only": true,
  "stage_loss_weight": 0.7,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.02,
  "stage_sequence_loss_weight": 0.0,
  "stage_max_forward_step": 1.5,
  "stage_postprocess": "none",
  "include_valid_mask_as_channels": true,
  "use_relative_doy": true,
  "use_aux_features": true,
  "aux_feature_set": "summary",
  "crop_class_weight_mode": "sqrt_inverse_freq",
  "point_crop_consistency_loss_weight": 0.1,
  "random_time_shift_days": 0,
  "query_doy_dropout_prob": 0.0,
  "time_doy_dropout_prob": 0.0,
  "min_lr": 0.0,
  "checkpoint_metric": "val_crop_macro_f1_consistent",
  "tie_breaker_metric": "val_joint_accuracy_consistent",
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "token_patch_size": 3,
    "transformer_dim": 320,
    "temporal_layers": 6,
    "spatial_layers": 6,
    "attention_heads": 8,
    "mlp_ratio": 4.0,
    "dropout": 0.18,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_query_doy": true,
    "use_time_doy": true,
    "time_encoding_type": "fourier",
    "query_encoding_type": "fourier",
    "time_encoding_harmonics": 8,
    "aux_hidden_dim": 96,
    "aux_target": "crop_only",
    "use_relative_query_bias": true,
    "use_direct_query_logit_bias": true
  },
  "selection_rule": "C29 submission-oriented TSViT: evaluate crop after the same point-level consistency used in submission, add mild crop-balancing and per-point crop-consistency regularization, enable relative DOY for cross-region season-shift robustness, and route summary aux features only to the crop head."
}
