{
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "split_csv": "artifacts/splits/train_val_split.csv",
  "output_dir": "artifacts/models/c25_relative_doy_fourier_val",
  "seed": 42,
  "batch_size": 256,
  "epochs": 200,
  "learning_rate": 0.0004,
  "weight_decay": 0.03,
  "num_workers": 4,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 2,
  "clip_grad_norm": 1.0,
  "scheduler": "cosine",
  "warmup_epochs": 5,
  "early_stopping_patience": 30,
  "save_best_only": true,
  "stage_loss_weight": 0.6,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.0,
  "include_valid_mask_as_channels": true,
  "use_relative_doy": true,
  "min_lr": 0.0,
  "checkpoint_metric": "val_competition_score",
  "tie_breaker_metric": "val_loss",
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "cnn_embedding_dim": 256,
    "transformer_dim": 256,
    "transformer_layers": 4,
    "attention_heads": 8,
    "dropout": 0.18,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_query_doy": true,
    "use_time_doy": true,
    "time_encoding_type": "fourier",
    "query_encoding_type": "fourier",
    "time_encoding_harmonics": 6
  },
  "selection_rule": "C25: C20 Fourier architecture with series-center-relative DOY encoding. Both time_doy and query_doy are shifted by subtracting the mean DOY of the sample's valid timesteps. Hypothesis: a test region planted 45 days earlier produces the same relative fingerprint as training, breaking calendar date memorization."
}
