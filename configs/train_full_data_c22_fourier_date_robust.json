{
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "output_dir": "artifacts/models/full_data_c22_fourier_date_robust",
  "seed": 42,
  "batch_size": 256,
  "epochs": 90,
  "learning_rate": 0.0004,
  "weight_decay": 0.03,
  "num_workers": 6,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 2,
  "clip_grad_norm": 1.0,
  "scheduler": "cosine",
  "warmup_epochs": 5,
  "stage_loss_weight": 0.6,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.0,
  "include_valid_mask_as_channels": true,
  "min_lr": 0.0,
  "use_aux_features": false,
  "random_time_shift_days": 60,
  "query_doy_dropout_prob": 0.55,
  "time_doy_dropout_prob": 0.20,
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "cnn_embedding_dim": 256,
    "transformer_dim": 256,
    "transformer_layers": 4,
    "attention_heads": 8,
    "dropout": 0.18,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_query_doy": true,
    "use_time_doy": true,
    "time_encoding_type": "fourier",
    "query_encoding_type": "fourier",
    "time_encoding_harmonics": 6
  },
  "selection_rule": "C22 combines C20 Fourier architecture (lowest recorded loss 0.0014, best temporal encoding) with C19 date augmentation (60-day shift + 55% query DOY dropout + 20% time DOY dropout). Neither was tried together before. Fourier encoding provides richer seasonal position representation while date augmentation forces reliance on spectral features rather than date memorization. Full-data training for 90 epochs."
}
