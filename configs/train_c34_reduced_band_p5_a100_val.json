{
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "split_csv": "artifacts/splits/train_val_split.csv",
  "output_dir": "artifacts/models/c34_reduced_band_p5_a100_val",
  "seed": 42,
  "batch_size": 1024,
  "epochs": 160,
  "learning_rate": 0.0003,
  "weight_decay": 0.03,
  "num_workers": 8,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 1,
  "persistent_workers": true,
  "prefetch_factor": 4,
  "clip_grad_norm": 1.0,
  "scheduler": "cosine",
  "warmup_epochs": 8,
  "early_stopping_patience": 28,
  "save_best_only": true,
  "crop_loss_weight": 0.25,
  "stage_loss_weight": 1.0,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.0,
  "stage_label_smoothing": 0.03,
  "include_valid_mask_as_channels": true,
  "min_lr": 0.0,
  "checkpoint_metric": "val_competition_score",
  "tie_breaker_metric": "val_loss",
  "disabled_bands": ["B01", "B09"],
  "use_aux_features": true,
  "aux_feature_set": "phenology_light",
  "use_relative_doy": true,
  "stage_ordinal_loss_weight": 0.1,
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "cnn_embedding_dim": 288,
    "transformer_dim": 288,
    "transformer_layers": 5,
    "attention_heads": 8,
    "dropout": 0.2,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_query_doy": true,
    "use_time_doy": true,
    "time_encoding_type": "fourier",
    "query_encoding_type": "fourier",
    "time_encoding_harmonics": 6,
    "aux_hidden_dim": 96,
    "aux_target": "stage_only",
    "use_cross_series_query": true
  },
  "selection_rule": "Deterministic A100 validation run for the reduced-band P5 candidate. Change disabled_bands after reading the band-importance report."
}
