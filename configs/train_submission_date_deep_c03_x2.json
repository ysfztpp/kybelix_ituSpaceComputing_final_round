{
  "dataset_npz": "artifacts/patches_clean/train_cnn_transformer_15x15.npz",
  "normalization_json": "artifacts/normalization/train_patch_band_stats.json",
  "split_csv": "artifacts/splits/train_val_split.csv",
  "output_dir": "artifacts/models/modeldev_deep_c03_x2",
  "seed": 42,
  "batch_size": 256,
  "epochs": 100,
  "learning_rate": 0.0003,
  "weight_decay": 0.03,
  "num_workers": 4,
  "device": "auto",
  "amp": true,
  "gradient_accumulation_steps": 1,
  "clip_grad_norm": 1.0,
  "scheduler": "cosine",
  "warmup_epochs": 5,
  "early_stopping_patience": 14,
  "save_best_only": true,
  "stage_loss_weight": 0.6,
  "rice_stage_loss_only": true,
  "label_smoothing": 0.0,
  "include_valid_mask_as_channels": true,
  "checkpoint_metric": "val_competition_score",
  "tie_breaker_metric": "val_loss",
  "min_lr": 0.000001,
  "use_aux_features": false,
  "model": {
    "in_channels": 24,
    "patch_size": 15,
    "cnn_embedding_dim": 256,
    "transformer_dim": 256,
    "transformer_layers": 8,
    "attention_heads": 8,
    "dropout": 0.2,
    "num_crop_classes": 3,
    "num_phenophase_classes": 7,
    "use_query_doy": true,
    "use_time_doy": true
  },
  "training_note": "Deep C03-style model: same inputs as the best reproduced baseline, but with 8 Transformer layers instead of 4. Batch size/lr are slightly reduced for stability."
}
